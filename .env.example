# Required: Full URL to the n8n webhook endpoint
N8N_WEBHOOK_URL=http://165.245.221.174:5678/webhook/maps-query

# Optional: Secret for X-Webhook-Secret header authentication
N8N_WEBHOOK_SECRET=

# Optional: Maximum character length for search input (default: 500)
MAX_MESSAGE_LENGTH=500

# Optional: Timeout for n8n webhook request in milliseconds (default: 120000)
REQUEST_TIMEOUT_MS=120000
